generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members          OrganizationMember[]
  projects         Project[]            @relation("ProjectOwnerOrg")
  supplier         Supplier?
  cloudConnections CloudConnection[]
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified DateTime?
  phone         String?
  avatarUrl     String?
  password      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orgMembers       OrganizationMember[]
  createdProjects  Project[]            @relation("ProjectCreator")
  operatedProjects Project[]            @relation("ProjectOperator")
  projectMembers   ProjectMember[]
  agentSessions    AgentSession[]
  operationLogs    OperationLog[]
  skills           Skill[]              @relation("SkillAuthor")
  cloudConnections CloudConnection[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId, role])
}

model Supplier {
  id              String  @id @default(cuid())
  organizationId  String  @unique
  capabilityTags  Json?
  supportedModes  Json?
  qualityLevel    String?
  efficiencyRange String?
  riskNote        String?
  status          String  @default("ACTIVE")

  organization Organization  @relation(fields: [organizationId], references: [id])
  tasks        ProjectTask[]
}

model Project {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  mode            String
  ownerOrgId      String
  creatorId       String
  operatorId      String?
  executionStatus String    @default("DRAFT")
  operationStatus String    @default("NO_NEED")
  currentStage    String    @default("CREATE")
  priority        String?
  startDate       DateTime?
  expectedEndDate DateTime?
  completedAt     DateTime?
  budgetName      String?
  budgetAmount    Float?
  companyName     String?
  departmentName  String?
  contactName     String?
  contactInfo     String?
  currentRisk     String?
  nextAction      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  ownerOrg       Organization           @relation("ProjectOwnerOrg", fields: [ownerOrgId], references: [id])
  creator        User                   @relation("ProjectCreator", fields: [creatorId], references: [id])
  operator       User?                  @relation("ProjectOperator", fields: [operatorId], references: [id])
  members        ProjectMember[]
  requirement    ProjectRequirement?
  stages         ProjectStage[]
  tasks          ProjectTask[]
  datasets       Dataset[]
  toolConfigs    ProjectToolConfig[]
  prelabelRuns   PrelabelRun[]
  qualityEvents  QualityEvent[]
  modelBindings  ProjectModelBinding[]
  trainingRuns   ModelRun[]
  agentSessions  AgentSession[]
  operationLogs  OperationLog[]
  retrospectives ProjectRetrospective[]
  supplierChats  SupplierChat[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String
  canEdit   Boolean  @default(false)
  canAudit  Boolean  @default(false)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId, role])
}

model ProjectRequirement {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  title               String
  demandType          String
  dataModality        String
  scenario            String?
  estimatedVolume     Int?
  acceptanceCriteria  String?
  safetyRequirement   String?
  sampleStatus        String?
  rawDocumentUrl      String?
  agentStructuredJson Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

model ProjectStage {
  id          String    @id @default(cuid())
  projectId   String
  type        String
  status      String    @default("PENDING")
  summary     String?
  startedAt   DateTime?
  completedAt DateTime?
  sortOrder   Int

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, type])
}

model ProjectTask {
  id              String    @id @default(cuid())
  projectId       String
  name            String
  executorType    String
  supplierId      String?
  stage           String
  status          String    @default("DRAFT")
  dataVolume      Int?
  estimatedEffort Float?
  actualEffort    Float?
  plannedStart    DateTime?
  plannedEnd      DateTime?
  actualEnd       DateTime?
  risk            String?
  resultSummary   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project       Project        @relation(fields: [projectId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  datasets      Dataset[]
  qualityEvents QualityEvent[]
  chats         SupplierChat[]
}

model Dataset {
  id          String   @id @default(cuid())
  projectId   String
  taskId      String?
  name        String
  type        String
  modality    String?
  itemCount   Int?
  format      String?
  storagePath String?
  version     String   @default("v1")
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project          @relation(fields: [projectId], references: [id])
  task      ProjectTask?     @relation(fields: [taskId], references: [id])
  files     FileObject[]
  versions  DatasetVersion[]
  modelRuns ModelRun[]
}

model DatasetVersion {
  id          String   @id @default(cuid())
  datasetId   String
  version     String
  changeNote  String?
  itemCount   Int?
  storagePath String?
  createdById String?
  createdAt   DateTime @default(now())

  dataset Dataset @relation(fields: [datasetId], references: [id])

  @@unique([datasetId, version])
}

model FileObject {
  id          String   @id @default(cuid())
  datasetId   String?
  filename    String
  mimeType    String?
  sizeBytes   BigInt?
  storagePath String
  checksum    String?
  assetType   String?
  createdAt   DateTime @default(now())

  dataset Dataset? @relation(fields: [datasetId], references: [id])
}

model PublicAsset {
  id          String   @id @default(cuid())
  type        String
  name        String
  source      String?
  license     String?
  modality    String?
  taskType    String?
  format      String?
  description String?
  tags        Json?
  url         String?
  metadata    Json?
  isOfficial  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CloudConnection {
  id           String    @id @default(cuid())
  name         String
  type         String    // OWN_CLOUD | THIRD_PARTY
  provider     String    // COMPANY_CLOUD | ALIYUN_OSS | AWS_S3 | TENCENT_COS | HUAWEI_OBS | MINIO
  ownerOrgId   String?
  creatorId    String
  config       Json      // endpoint, region, bucket, prefix, credentials, etc.
  status       String    @default("ACTIVE")
  lastTestedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organization Organization? @relation(fields: [ownerOrgId], references: [id])
  creator      User          @relation(fields: [creatorId], references: [id])
}

model ToolTemplate {
  id           String   @id @default(cuid())
  name         String
  toolType     String
  modality     String?
  taskType     String?
  configSchema Json?
  previewMode  String?
  description  String?
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())

  configs ProjectToolConfig[]
}

model ProjectToolConfig {
  id          String   @id @default(cuid())
  projectId   String
  templateId  String?
  name        String
  configJson  Json
  previewJson Json?
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project       @relation(fields: [projectId], references: [id])
  template ToolTemplate? @relation(fields: [templateId], references: [id])
}

model PrelabelRun {
  id          String    @id @default(cuid())
  projectId   String
  modelName   String
  imageName   String?
  inputPath   String?
  boxCount    Int       @default(0)
  status      String    @default("PREVIEW")
  resultJson  Json?
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model QualityEvent {
  id          String    @id @default(cuid())
  projectId   String
  taskId      String?
  ruleId      String?
  type        String
  severity    String
  sampleScope String?
  location    String?
  impact      String?
  status      String    @default("OPEN")
  action      String?
  rootCause   String?
  needRework  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  project Project      @relation(fields: [projectId], references: [id])
  task    ProjectTask? @relation(fields: [taskId], references: [id])
}

model QualityScript {
  id          String   @id @default(cuid())
  name        String
  targetError String
  modality    String?
  scriptType  String
  prompt      String?
  code        String?
  configJson  Json?
  createdBy   String?
  visibility  String   @default("PRIVATE")
  createdAt   DateTime @default(now())
}

model ModelEntity {
  id          String   @id @default(cuid())
  name        String
  taskType    String
  ownerOrgId  String?
  source      String?
  description String?
  createdAt   DateTime @default(now())

  bindings ProjectModelBinding[]
  runs     ModelRun[]
}

model ProjectModelBinding {
  id        String   @id @default(cuid())
  projectId String
  modelId   String
  purpose   String?
  status    String   @default("BOUND")
  createdAt DateTime @default(now())

  project Project     @relation(fields: [projectId], references: [id])
  model   ModelEntity @relation(fields: [modelId], references: [id])

  @@unique([projectId, modelId])
}

model ModelRun {
  id          String   @id @default(cuid())
  projectId   String?
  modelId     String
  datasetId   String?
  runName     String
  externalUrl String?
  tool        String?
  status      String   @default("IMPORTED")
  metricsJson Json?
  badcaseJson Json?
  conclusion  String?
  createdAt   DateTime @default(now())

  project         Project?                 @relation(fields: [projectId], references: [id])
  model           ModelEntity              @relation(fields: [modelId], references: [id])
  dataset         Dataset?                 @relation(fields: [datasetId], references: [id])
  recommendations TrainingRecommendation[]
}

model TrainingRecommendation {
  id           String   @id @default(cuid())
  modelRunId   String
  title        String
  reason       String
  nextDataNeed String?
  priority     String?
  generatedBy  String   @default("AGENT")
  accepted     Boolean  @default(false)
  createdAt    DateTime @default(now())

  modelRun ModelRun @relation(fields: [modelRunId], references: [id])
}

model AgentSession {
  id        String   @id @default(cuid())
  projectId String?
  userId    String
  context   String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project?       @relation(fields: [projectId], references: [id])
  user     User           @relation(fields: [userId], references: [id])
  messages AgentMessage[]
  actions  AgentAction[]
}

model AgentMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  session AgentSession @relation(fields: [sessionId], references: [id])
}

model AgentAction {
  id           String    @id @default(cuid())
  sessionId    String
  projectId    String?
  actionType   String
  targetEntity String?
  targetId     String?
  status       String    @default("PREVIEW")
  previewJson  Json
  diffJson     Json?
  resultJson   Json?
  authorizedBy String?
  authorizedAt DateTime?
  executedAt   DateTime?
  createdAt    DateTime  @default(now())

  session AgentSession @relation(fields: [sessionId], references: [id])
}

model OperationLog {
  id         String   @id @default(cuid())
  projectId  String?
  userId     String?
  actorRole  String
  action     String
  detail     String?
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
}

model ProjectRetrospective {
  id                  String   @id @default(cuid())
  projectId           String
  outcome             String
  successScore        Int?
  summary             String
  reusablePattern     Json?
  isTrainingCandidate Boolean  @default(false)
  desensitized        Boolean  @default(false)
  createdAt           DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model AgentTrainingExample {
  id             String   @id @default(cuid())
  sourceType     String
  sourceId       String?
  category       String?
  input          String
  expectedOutput String
  context        String?
  qualityScore   Float?
  tags           Json?
  approved       Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model SupplierChat {
  id            String   @id @default(cuid())
  projectId     String
  taskId        String?
  senderRole    String
  senderId      String
  senderName    String
  content       String
  contentType   String   @default("TEXT")
  attachmentUrl String?
  createdAt     DateTime @default(now())

  project     Project          @relation(fields: [projectId], references: [id])
  task        ProjectTask?     @relation(fields: [taskId], references: [id])
  annotation  ChatAnnotation?

  @@index([projectId, createdAt])
}

model ChatAnnotation {
  id             String   @id @default(cuid())
  chatId         String   @unique
  isValuable     Boolean  @default(false)
  category       String?
  correctedReply String?
  note           String?
  annotatedBy    String
  annotatedAt    DateTime @default(now())
  reviewStatus   String   @default("PENDING_ANNOTATION")
  reviewedBy     String?
  reviewedAt     DateTime?
  trainingId     String?

  chat             SupplierChat          @relation(fields: [chatId], references: [id])
}

model Skill {
  id          String   @id @default(cuid())
  authorId    String
  name        String
  category    String
  description String?
  visibility  String   @default("PRIVATE")
  official    Boolean  @default(false)
  usageCount  Int      @default(0)
  rating      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User           @relation("SkillAuthor", fields: [authorId], references: [id])
  versions SkillVersion[]
}

model SkillVersion {
  id           String   @id @default(cuid())
  skillId      String
  version      String
  inputSchema  Json?
  outputSchema Json?
  prompt       String?
  code         String?
  changelog    String?
  createdAt    DateTime @default(now())

  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([skillId, version])
}

model OfficialPost {
  id         String    @id @default(cuid())
  title      String
  type       String
  content    String
  startsAt   DateTime?
  endsAt     DateTime?
  visibility String    @default("PUBLIC")
  createdAt  DateTime  @default(now())
}

// ============================================================
// 知识资产层（Agent中台核心）
// ============================================================

model Knowledge {
  id            String    @id @default(cuid())
  title         String
  content       String
  type          String    // 标注规则 / 质量案例 / 项目经验 / SOP流程 / 数据经验
  category      String?   // 细分类目
  status        String    @default("DRAFT") // DRAFT / PENDING / PUBLISHED / ARCHIVED
  confidence    Int       @default(80)      // 可信度 0-100
  tags          String?
  sourceType    String?   // 来源类型：SupplierChat / QualityEvent / ProjectRetrospective / AgentMessage
  sourceId      String?   // 来源记录ID
  creatorId     String?
  reviewerId    String?
  publisherId   String?
  callCount     Int       @default(0)       // 被Agent调用次数
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  publishedAt   DateTime?

  relations      KnowledgeRelation[]
  embedding      KnowledgeEmbedding?
}

model KnowledgeRelation {
  id           String   @id @default(cuid())
  knowledgeId  String
  relationType String   // SOURCE_FROM / APPLY_TO / RELATED_TO / IMPACT
  targetType   String   // Project / ProjectTask / Dataset / DatasetVersion / QualityEvent / Supplier / SupplierChat / ProjectRetrospective
  targetId     String
  createdBy    String?
  createdAt    DateTime @default(now())

  knowledge Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([knowledgeId])
}

model KnowledgeEmbedding {
  id              String    @id @default(cuid())
  knowledgeId     String    @unique
  vectorId        String?   // 向量数据库中的ID
  embeddingStatus String    @default("PENDING") // PENDING / PROCESSING / INDEXED / FAILED
  chunkCount      Int       @default(0)
  vectorDimension Int?
  modelName       String?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  knowledge Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
}

// ============================================================
// Workflow Runtime 持久化层
// ============================================================

model AgentWorkflow {
  id            String    @id @default(cuid())
  name          String
  description   String?
  status        String    @default("DRAFT") // DRAFT / TESTING / REVIEW / PUBLISHED / OFFLINE
  version       String    @default("1.0.0")
  workflowJson  String?   // 画布完整状态（节点+连线）JSON备份
  currentVersion String   @default("1.0.0")
  category      String?   // 需求分析 / 质量诊断 / 供应商评估 / 数据治理 / 项目复盘
  creatorId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  publishedAt   DateTime?

  nodes    AgentWorkflowNode[]
  edges    AgentWorkflowEdge[]
  versions AgentVersion[]
  testCases AgentTestCase[]
  executions AgentNodeExecution[]
  sessionTraces AgentSessionTrace[]
}

model AgentWorkflowNode {
  id            String   @id @default(cuid())
  workflowId    String
  nodeType      String   // INPUT / INTENT_CLASSIFIER / ENTITY_EXTRACTOR / BUSINESS_ROUTER / CONDITION / BUSINESS_DATA_QUERY / KNOWLEDGE_RETRIEVAL / TOOL / LLM / AGENT / OUTPUT
  nodeName      String
  description   String?
  inputSchema   String?  // JSON: 输入 Schema（变量定义）
  outputSchema  String?  // JSON: 输出 Schema（变量定义）
  configJson    String?  // 节点业务配置：绑定的Skill/DataTable/Knowledge/Tool/Model/条件表达式
  runtimeConfig String?  // JSON: 运行时配置（超时/重试/回退）
  positionX     Int      @default(0)
  positionY     Int      @default(0)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workflow   AgentWorkflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  executions AgentNodeExecution[]
  variables  WorkflowVariable[]

  @@index([workflowId])
}

model WorkflowVariable {
  id                 String   @id @default(cuid())
  workflowNodeId     String
  name               String   // 变量名：query / intent / entities / result
  type               String   // string / number / boolean / object / array
  source             String?  // 来源节点ID
  sourceField        String?  // 来源字段路径：intent / entities.project_id
  description        String?
  defaultValue       String?  // JSON 默认值
  createdAt          DateTime @default(now())

  node   AgentWorkflowNode @relation(fields: [workflowNodeId], references: [id], onDelete: Cascade)

  @@unique([workflowNodeId, name])
  @@index([workflowNodeId])
}

model AgentWorkflowEdge {
  id            String   @id @default(cuid())
  workflowId    String
  sourceNodeId  String
  targetNodeId  String
  sourcePort    String?  // 出口端口标识（如 out / true / false）
  targetPort    String?  // 入口端口标识（如 in）
  condition     String?  // 条件表达式：condition / always / default
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  workflow AgentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}

model AgentVersion {
  id            String   @id @default(cuid())
  workflowId    String
  version       String   // 语义化版本号 v1.0.0
  skillVersion  String?  // Skill版本快照
  promptVersion String?  // Prompt模板版本
  toolConfig    String?  // JSON：工具配置快照
  knowledgeScope String? // JSON：知识范围快照
  modelVersion  String?  // ModelEntity版本快照
  nodesSnapshot String?  // JSON：节点快照
  edgesSnapshot String?  // JSON：连线快照
  status        String   @default("DRAFT") // DRAFT / TESTING / REVIEW / PUBLISHED / ROLLBACK
  changelog     String?
  createdBy     String?
  createdAt     DateTime @default(now())
  publishedAt   DateTime?

  workflow AgentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId, status])
}

model AgentTestCase {
  id          String   @id @default(cuid())
  workflowId  String?
  name        String
  input       String
  expected    String?
  category    String?
  tags        String?
  passed      Boolean?
  score       Float?
  createdAt   DateTime @default(now())

  workflow AgentWorkflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
}

// ============================================================
// Runtime 执行链路记录
// ============================================================

model AgentSessionTrace {
  id            String   @id @default(cuid())
  sessionId     String?  // 关联 AgentSession
  workflowId    String?  // 关联 AgentWorkflow
  workflowName  String?
  version       String?  // 运行时使用的版本
  userId        String?
  question      String   // 用户问题
  status        String   @default("RUNNING") // RUNNING / SUCCESS / FAILED / PARTIAL
  totalTokens   Int      @default(0)
  durationMs    Int      @default(0)
  errorMessage  String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  workflow    AgentWorkflow?       @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  nodeSteps   AgentNodeExecution[]

  @@index([sessionId])
  @@index([workflowId])
  @@index([startedAt])
}

model AgentNodeExecution {
  id            String    @id @default(cuid())
  traceId       String
  workflowId    String?
  nodeId        String?   // AgentWorkflowNode.id
  nodeType      String    // INPUT / AGENT / DATA / KNOWLEDGE / TOOL / LLM / CONDITION / OUTPUT
  nodeName      String
  stepOrder     Int       @default(0)
  inputJson     String?   // JSON
  outputJson    String?   // JSON
  tokens        Int       @default(0)
  durationMs    Int       @default(0)
  status        String    @default("RUNNING") // RUNNING / SUCCESS / FAILED / SKIPPED
  errorMessage  String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  trace   AgentSessionTrace   @relation(fields: [traceId], references: [id], onDelete: Cascade)
  node    AgentWorkflowNode?  @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  workflow AgentWorkflow?     @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@index([traceId, stepOrder])
  @@index([nodeId])
}
